generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ProfileSetting {
  id         String   @id @default("main")
  name       String
  bio        String
  avatarUrl  String   @map("avatar_url")
  footerText String   @map("footer_text")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("profile_settings")
}

model SiteSetting {
  id             String   @id @default("main")
  siteTitle      String   @map("site_title")
  seoDescription String   @map("seo_description")
  defaultTheme   String   @default("system") @map("default_theme")
  analyticsId    String   @default("") @map("analytics_id")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

model Category {
  id        String       @id
  name      String
  icon      String       @default("category")
  sortOrder Int          @default(0) @map("sort_order")
  isActive  Boolean      @default(true) @map("is_active")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  links     PortalLink[]

  @@map("categories")
}

model PortalLink {
  id          String    @id
  title       String
  description String    @default("")
  url         String
  icon        String    @default("link")
  categoryId  String?   @map("category_id")
  sortOrder   Int       @default(0) @map("sort_order")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@map("portal_links")
}

model SocialLink {
  id        String  @id
  label     String
  icon      String  @default("link")
  url       String
  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  @@map("social_links")
}

model FeaturedLink {
  id        String  @id
  label     String
  icon      String  @default("link")
  hint      String  @default("")
  url       String
  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  @@map("featured_links")
}

model VisitStat {
  id        String   @id @default(cuid())
  date      String   @unique
  visitors  Int      @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")

  uniques   VisitUnique[]

  @@map("visit_stats")
}

model VisitUnique {
  id        String   @id @default(cuid())
  date      String
  ipHash    String   @map("ip_hash")
  createdAt DateTime @default(now()) @map("created_at")
  visitStat VisitStat @relation(fields: [date], references: [date], onDelete: Cascade)

  @@unique([date, ipHash])
  @@map("visit_uniques")
}
